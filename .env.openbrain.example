# Open Brain Cloud Canary Environment Template
# Copy to .env.openbrain and fill with real values.
# .env.openbrain is gitignored — never commit it.
#
# Usage:
#   cp .env.openbrain.example .env.openbrain
#   chmod 600 .env.openbrain
#   # Edit .env.openbrain with real credentials
#   OPENBRAIN_ENV_FILE=.env.openbrain npx tsx scripts/v7b1.1-live-canary-execute.mjs

# Required: Supabase service_role key (rotated — not the old exposed key)
OPENBRAIN_API_KEY=sbp_your-new-rotated-key-here

# Required: v7B.1.1 authorization flag
V7B1_CANARY_AUTHORIZED=true

# Required: open kill switch for this run only
OPENBRAIN_WRITE_DISABLED=false

# Optional: Supabase project reference (public identifier)
# OPENBRAIN_PROJECT_REF=bgludgfrbyicqqdkdqds
